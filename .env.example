# =============================================================================
# docker-openresty-tool 环境变量配置
# =============================================================================
# 复制此文件为 .env 即可使用自定义配置
# docker-compose 会优先读取 .env 文件中的变量
# =============================================================================

# ---------------------------- 服务名称 ---------------------------------

# 容器名称（可选）
YOT_CONTAINER_NAME=yot
IMGPROXY_CONTAINER_NAME=imgproxy

# ---------------------------- Nginx 服务配置 ----------------------------

# Nginx 端口
NGX_PORT=80

# Nginx worker 数量
NGX_WORKER=auto

# 绑定的域名或 IP（_ 表示所有）
NGX_HOST=_

# 日志配置
NGX_LOG_FILE=false
NGX_LOG_LEVEL=warn

# 运行用户
UID=1000
GID=1000

# -------------------------- 图片缓存配置 ---------------------------------

# 缓存有效期 (30m, 1h, 2h, 1d, 2d, 7d, 30d)
OR_IMG_CACHE_VALID=2d

# 缓存最大磁盘使用
OR_IMG_CACHE_MAX=2g

# 非活跃文件删除时间
OR_IMG_CACHE_INACTIVE=60d

# 缓存目录
OR_IMG_CACHE_PATH=/data/cache

# 后台更新缓存 (on/off)
OR_IMG_CACHE_BACKGROUND_UPDATE=on

# 使用过期缓存条件
OR_IMG_CACHE_USE_STALE=error timeout updating http_500 http_502 http_503 http_504

# -------------------------- imgproxy 上游配置 ----------------------------

# imgproxy 服务地址（单机模式）
IMGPROXY_HOST=imgproxy
IMGPROXY_PORT=8080

# imgproxy 上游服务器列表（多机模式，逗号分隔，留空则使用单机模式）
# 示例: IMGPROXY_UPSTREAM=imgproxy1:8080,imgproxy2:8080,imgproxy3:8080
IMGPROXY_UPSTREAM=

# -------------------------- 基本认证配置 ---------------------------------

# 格式: 用户名:密码（留空则不启用认证）
# 示例: OR_AUTH_USER=admin:secretpassword
OR_AUTH_USER=

# -------------------------- imgproxy 详细配置 ---------------------------

# 文件系统根目录（/ 允许访问任意绝对路径）
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/

# 禁用 imgproxy 自身缓存（yot 已处理）
IMGPROXY_DISABLE_CACHE=true

# imgproxy 缓存大小（留空则使用默认值，IMGPROXY_DISABLE_CACHE=true 时忽略）
IMGPROXY_CACHE_SIZE=

# imgproxy worker 数量（默认 1，yot 处理缓存）
IMGPROXY_WORKERS=1

# 最大源文件大小（字节）
IMGPROXY_MAX_SRC_FILESIZE=104857600

# 最大分辨率（像素）
IMGPROXY_MAX_RESOLUTION=66741696

# 保留颜色配置
IMGPROXY_STRIP_COLOR_PROFILE=Never

# 强制透明度
IMGPROXY_ENFORCE_TRANSPARENCY=false

# 压缩类型（留空则禁用）
IMGPROXY_GZIP_MIME_TYPES=

# 日志级别
IMGPROXY_LOG_LEVEL=warn

# 开发模式
IMGPROXY_DEV_MODE_STRICT=false

# IP 协议 (0=IPv4, 2=IPv6)
IMGPROXY_FAMILY=0

# WebDAV 配置（ZIP/CBZ 透明处理）
IMGPROXY_WEBDAV_ROOT=/webdav
IMGPROXY_WEBDAV_ENDPOINT=http://yot:5080
IMGPROXY_WEBDAV_USER=
IMGPROXY_WEBDAV_PASSWORD=

# -------------------------- RAM Disk 配置 -------------------------------

# RAM Disk 大小（默认 512m）
RAMDISK_SIZE=512m

# -------------------------- 端口配置 -----------------------------------

# yot HTTP 端口映射
YOT_HTTP_PORT=5080
