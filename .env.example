# =============================================================================
# docker-openresty-tool 环境变量配置
# =============================================================================
# 复制此文件为 .env 或直接修改 docker-compose.yml 中的环境变量
# docker-compose 会优先读取 .env 文件中的变量（如果存在）
# =============================================================================

# ---------------------------- Nginx 服务配置 ----------------------------

# Nginx 端口 (默认: 80)
NGX_PORT=80

# Nginx worker 数量 (默认: auto)
NGX_WORKER=auto

# 绑定的域名或 IP (默认: _ 表示所有)
NGX_HOST=_

# 日志配置
NGX_LOG_FILE=false
NGX_LOG_LEVEL=warn

# 运行用户 (默认: UID=1000, GID=1000)
UID=1000
GID=1000

# -------------------------- 图片缓存配置 ---------------------------------

# 缓存有效期 (默认: 2d)
# 可选: 30m, 1h, 2h, 1d, 2d, 7d, 30d
OR_IMG_CACHE_VALID=2d

# 缓存最大磁盘使用 (默认: 2g)
OR_IMG_CACHE_MAX=2g

# 非活跃文件删除时间 (默认: 60d)
OR_IMG_CACHE_INACTIVE=60d

# 缓存目录 (默认: /data/cache)
OR_IMG_CACHE_PATH=/data/cache

# 后台更新缓存 (默认: on)
OR_IMG_CACHE_BACKGROUND_UPDATE=on

# 使用过期缓存条件 (默认: error timeout updating http_500 http_502 http_503 http_504)
OR_IMG_CACHE_USE_STALE=error timeout updating http_500 http_502 http_503 http_504

# -------------------------- imgproxy 服务配置 ----------------------------

# imgproxy 上游服务器 (默认: imgproxy:8080)
# 支持多个服务器实现 round-robin 负载均衡，逗号分隔
# IMGPROXY_HOST=imgproxy
# IMGPROXY_PORT=8080
# IMGPROXY_UPSTREAM=imgproxy1:8080,imgproxy2:8080,imgproxy3:8080

# -------------------------- WebDAV 认证配置 ------------------------------

# 格式: 用户名:密码 (默认: 无认证)
# OR_AUTH_USER=admin:admin
