# ============================================================
# docker-openresty-tool Environment Variables
# ============================================================
# Copy this file to .env and customize as needed
# ============================================================

# ── Yot (OpenResty) ─────────────────────────────────────────

# Container name
YOT_CONTAINER_NAME=yot

# HTTP port mapping (internal:external)
YOT_HTTP_PORT=5080

# Public access port (no authentication, internal:external)
# Port 82 inside container - external port 5082 by default
OR_NO_AUTH_PORT=5082

# Nginx worker processes
NGX_WORKER=auto

# Nginx log level: debug, info, notice, warn, error, crit
NGX_LOG_LEVEL=warn

# ── /img/ Cache ─────────────────────────────────────────────

# Cache validity for successful responses
OR_IMG_CACHE_VALID=2d

# Maximum cache size
OR_IMG_CACHE_MAX=2g

# Cache inactive time before removal
OR_IMG_CACHE_INACTIVE=60d

# Cache directory path
OR_IMG_CACHE_PATH=/data/cache

# ── imgproxy Upstream ───────────────────────────────────────

# Remote imgproxy servers (comma-separated host:port)
# OR_IMGPROXY_UPSTREAM=imgproxy1:8080,imgproxy2:8080
OR_IMGPROXY_UPSTREAM=

# ── Authentication ───────────────────────────────────────────

# IP whitelist for bypass authentication (comma-separated, supports CIDR)
# Example: 192.168.1.0/24,10.0.0.1
OR_AUTH_IP_WHITELIST=

# Internal auth token for trusted services (imgproxy) to bypass IP whitelist
# Supports three modes:
#   1. OR_AUTH_BEARER: Authorization: Bearer <token> or User-Agent: <token>
#   2. OR_INTERNAL_AUTH_HEADER: X-Internal-Auth: <token> (legacy)
# Set the same value in both yot and imgproxy to enable authentication
OR_AUTH_BEARER=your_secret_key_here
OR_INTERNAL_AUTH_HEADER=

# Basic auth credentials (optional): format "username:password"
OR_AUTH_USER=gallery:test@123

# ── imgproxy ────────────────────────────────────────────────

# imgproxy container name
IMGPROXY_CONTAINER_NAME=imgproxy

# imgproxy external port mapping
IMGPROXY_EXTERNAL_PORT=5081

# Filesystem root for imgproxy (must be / for absolute path support)
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/

# Disable imgproxy cache (yot handles all caching)
IMGPROXY_DISABLE_CACHE=true

# imgproxy cache size (if enabled)
# IMGPROXY_CACHE_SIZE=1g

# Number of imgproxy workers
IMGPROXY_WORKERS=1

# Max source file size (100MB default)
IMGPROXY_MAX_SRC_FILESIZE=104857600

# Max image resolution (66MP default)
IMGPROXY_MAX_RESOLUTION=66741696

# Log level: debug, info, warn, error
IMGPROXY_LOG_LEVEL=warn

# User-Agent header for imgproxy requests (use with OR_AUTH_BEARER for authentication)
# Set to the same value as OR_AUTH_BEARER in yot
IMGPROXY_USER_AGENT=your_secret_key_here

# Strip color profile: Never, Always, WhenPossible, SDOnly
IMGPROXY_STRIP_COLOR_PROFILE=Never

# WebDAV settings for ZIP/CBZ access
# Use yot:5082 (port 82) - public access without authentication
IMGPROXY_WEBDAV_ROOT=/webdav
IMGPROXY_WEBDAV_ENDPOINT=http://yot:5082
# IMGPROXY_WEBDAV_USER=
# IMGPROXY_WEBDAV_PASSWORD=

# ── RAM Disk ────────────────────────────────────────────────

# RAM disk size for imgproxy temp files
RAMDISK_SIZE=512m

# User/Group IDs (match your host)
UID=1000
GID=1000
